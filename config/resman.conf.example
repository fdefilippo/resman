# ResMan Configuration File
# Location: /etc/resman.conf
#
# Legend: [D] = Dynamic (hot reload) | [S] = Static (requires restart)

# ========================
# PATHS [S]
# ========================
CGROUP_ROOT=/sys/fs/cgroup
CGROUP_BASE=resman
CREATED_CGROUPS_FILE=/var/run/resman/cgroups.txt
METRICS_CACHE_FILE=/var/run/resman/metrics.cache

# ========================
# TIMING [D]
# ========================
POLLING_INTERVAL=30
MIN_ACTIVE_TIME=60
METRICS_CACHE_TTL=15

# ========================
# TIMEOUT CONFIGURATION [S]
# ========================
# Timeout for critical operations (v1.18.3+)
#
# CGROUP_OPERATION_TIMEOUT: Timeout for cgroup operations (process migration)
# Default: 5 seconds
# Increase on slow systems or with many processes
# CGROUP_OPERATION_TIMEOUT=5
#
# CGROUP_RETRY_DELAY_MS: Delay between cgroup operation retries
# Default: 100 milliseconds
# CGROUP_RETRY_DELAY_MS=100
#
# MCP_SHUTDOWN_TIMEOUT: Timeout for MCP server shutdown
# Default: 10 seconds
# MCP_SHUTDOWN_TIMEOUT=10

# ========================
# THRESHOLDS (percentages) [D]
# ========================
CPU_THRESHOLD=75             # Activate limits if user CPU >= 75%
CPU_RELEASE_THRESHOLD=40     # Release limits if user CPU < 40%

# THRESHOLD TIME WINDOW (seconds) [D]
# CPU_THRESHOLD_DURATION: Wait time before activating limits after threshold breach
# Useful to avoid activation for temporary spikes (e.g., deployments, backups)
# Default: 90 seconds (3 cycles of 30s)
# Set to 0 for immediate activation (legacy behavior)
#
# Examples:
# # Immediate activation (pre-v1.15.0 behavior)
# CPU_THRESHOLD_DURATION=0
#
# # Wait 90 seconds (default)
# CPU_THRESHOLD_DURATION=90
#
# # Wait 3 minutes (critical environments)
# CPU_THRESHOLD_DURATION=180
CPU_THRESHOLD_DURATION=90

# ========================
# CPU LIMITS [D]
# ========================
# cpu.max format: "quota period"
# total_cores = Quota / Period
# Example:  50000 100000 -> 1/2 core
# Example: 300000 100000 -> 3 cores
# Example: 200000 100000 -> 2 full cores
CPU_QUOTA_NORMAL="max 100000"
CPU_QUOTA_LIMITED="50000 100000"

# ========================
# RAM LIMITS [D]
# ========================
# Enable/disable RAM limiting via cgroups v2
# When enabled, memory.max limits are applied to user cgroups
# RAM_LIMIT_ENABLED: true = enable RAM limits, false = disable
#
# RAM_THRESHOLD: Percentage of total user RAM to activate limits
# RAM_RELEASE_THRESHOLD: Percentage to release limits
# Format: percentages 1-100
#
# RAM_QUOTA_LIMITED: Total RAM limit in bytes or with suffix (K/M/G/T)
# Examples: "2147483648" (2GB in bytes), "2G", "512M"
#
# RAM_QUOTA_PER_USER: Per-user RAM limit (when limits are active)
# Examples: "536870912" (512MB), "512M", "1G"
#
# DISABLE_SWAP: Set memory.swap.max=0 to prevent swap usage
# WARNING: May cause OOM kills if a process exceeds the RAM limit
#
# RAM_HIGH_RATIO: Ratio between memory.high and memory.max (0.0-1.0)
# memory.high is a "soft" limit: when exceeded, the kernel applies
# throttling and aggressive reclaim, but does NOT kill processes (unlike memory.max)
# Examples: 0.8 = memory.high is 80% of memory.max
#           0.9 = memory.high is 90% of memory.max
#           0 = disabled (memory.max only, legacy behavior)
#
# Examples:
# # RAM limits disabled (default)
# RAM_LIMIT_ENABLED=false
#
# # Enable RAM limits with thresholds and quotas
# RAM_LIMIT_ENABLED=true
# RAM_THRESHOLD=75
# RAM_RELEASE_THRESHOLD=40
# RAM_QUOTA_LIMITED=2G
# RAM_QUOTA_PER_USER=512M
# DISABLE_SWAP=false
# RAM_HIGH_RATIO=0.8
#
# # Strict mode (no swap, high at 90%)
# RAM_LIMIT_ENABLED=true
# RAM_THRESHOLD=80
# RAM_RELEASE_THRESHOLD=50
# RAM_QUOTA_LIMITED=4G
# RAM_QUOTA_PER_USER=1G
# DISABLE_SWAP=true
# RAM_HIGH_RATIO=0.9
#
# # Completely disable RAM limits (monitoring only)
# # RAM metrics continue to work, but no limits are applied
# RAM_LIMIT_ENABLED=false
#
# # Disable RAM limits but keep Workload Pattern Detection for CPU
# # If AUTODETECT_PATTERNS=true, empty RAM quotas to prevent RAM limits
# RAM_LIMIT_ENABLED=false
# AUTODETECT_PATTERNS=true
# BATCH_NIGHT_RAM_QUOTA=
# INTERACTIVE_RAM_QUOTA=
#
#
RAM_LIMIT_ENABLED=false
RAM_THRESHOLD=75
RAM_RELEASE_THRESHOLD=40
RAM_QUOTA_LIMITED=2G
RAM_QUOTA_PER_USER=512M
DISABLE_SWAP=false
RAM_HIGH_RATIO=0.8

# ========================
# RAM USER INCLUDE/EXCLUDE LISTS [D]
# ========================
# Separate lists for RAM limits (if different from CPU limits)
# RAM_USER_INCLUDE_LIST: If specified, include ONLY matching users
# RAM_USER_EXCLUDE_LIST: If specified, EXCLUDE users from RAM limits
# Format: comma-separated regex patterns
#
# Examples:
# # Only specific users for RAM
# RAM_USER_INCLUDE_LIST=^www.*,^app-.*
#
# # Exclude system users from RAM limits
# RAM_USER_EXCLUDE_LIST=^mysql,^postgres,^redis
#
# # Empty = use default behavior (include all, exclude root)
# RAM_USER_INCLUDE_LIST=
# RAM_USER_EXCLUDE_LIST=root
#
RAM_USER_INCLUDE_LIST=
RAM_USER_EXCLUDE_LIST=root

# ========================
# IO LIMITS [D]
# ========================
# Enable/disable IO limiting via cgroups v2 io controller
# IO_LIMIT_ENABLED: true = enable IO limits, false = disable
#
# IO_THRESHOLD: Percentage of total user IO to activate limits
# IO_RELEASE_THRESHOLD: Percentage to release limits
#
# IO_READ_BPS: Per-user read bandwidth limit (bytes/s with K/M/G/T suffix)
# IO_WRITE_BPS: Per-user write bandwidth limit
# IO_READ_IOPS: Per-user read IOPS limit (0 = unlimited)
# IO_WRITE_IOPS: Per-user write IOPS limit (0 = unlimited)
#
# IO_DEVICE_FILTER: "all" = apply to all devices, or "8:0" for specific device
# IO_THRESHOLD_DURATION: Seconds to wait before activating IO limits (0 = immediate)
#   Useful to avoid throttling on brief IO spikes (e.g., backups, builds, file copies)
#
# Examples:
# # IO limits disabled (default)
# IO_LIMIT_ENABLED=false
#
# # Enable IO limits with thresholds and quotas
# IO_LIMIT_ENABLED=true
# IO_THRESHOLD=75
# IO_RELEASE_THRESHOLD=40
# IO_READ_BPS=100M
# IO_WRITE_BPS=50M
# IO_READ_IOPS=1000
# IO_WRITE_IOPS=500
# IO_DEVICE_FILTER=all
#
# # Strict mode (lower limits)
# IO_LIMIT_ENABLED=true
# IO_THRESHOLD=80
# IO_RELEASE_THRESHOLD=50
# IO_READ_BPS=50M
# IO_WRITE_BPS=25M
# IO_READ_IOPS=500
# IO_WRITE_IOPS=250
#
IO_LIMIT_ENABLED=false
IO_THRESHOLD=75
IO_RELEASE_THRESHOLD=40
IO_READ_BPS=100M
IO_WRITE_BPS=50M
IO_READ_IOPS=1000
IO_WRITE_IOPS=500
IO_DEVICE_FILTER=all
IO_THRESHOLD_DURATION=0

# IO Starvation Auto-Remediation
# Detects when a user is IO-throttled for too long and temporarily
# increases limits to prevent prolonged performance degradation.
# Requires kernel >= 4.20 with CONFIG_PSI=y for PSI detection.
# IO_REMEDIATION_ENABLED: true = enable auto-remediation
# IO_STARVATION_THRESHOLD: Seconds of continuous throttling before acting
# IO_STARVATION_CHECK_INTERVAL: Check frequency (seconds)
# IO_BOOST_MULTIPLIER: Multiplier for temporary limits (2.0 = 2x)
# IO_BOOST_DURATION: Duration of boost in seconds
# IO_BOOST_MAX_PER_HOUR: Max boosts per user per hour
# IO_PSI_THRESHOLD: PSI some avg10 % threshold to consider starvation
# IO_REVERT_ON_NORMAL: true = revert limits when IO returns to normal
IO_REMEDIATION_ENABLED=false
IO_STARVATION_THRESHOLD=300
IO_STARVATION_CHECK_INTERVAL=30
IO_BOOST_MULTIPLIER=2.0
IO_BOOST_DURATION=600
IO_BOOST_MAX_PER_HOUR=3
IO_PSI_THRESHOLD=50
IO_REVERT_ON_NORMAL=true

# ========================
# LIMIT HOOK [D]
# ========================
# Optional notification/action when a user is newly limited.
# Script receives RESMAN_LIMIT_* environment variables.
# URL receives a JSON POST with uid, username, cpu_usage, shared_cgroup, timestamp.
LIMIT_HOOK_ENABLED=false
# LIMIT_HOOK_SCRIPT=/usr/local/bin/resman-user-limited
# LIMIT_HOOK_URL=https://example.internal/resman/user-limited
LIMIT_HOOK_TIMEOUT=10

# ========================
# PROMETHEUS [S]
# ========================
# Requires restart for: enable/disable, port, host, TLS, auth
# Metrics are updated dynamically, but server configuration is not
ENABLE_PROMETHEUS=false              # Enable metrics export
# SECURITY: Default bind is 127.0.0.1 (localhost only)
# Set to 0.0.0.0 to expose to all interfaces (NOT recommended without auth/TLS)
# PROMETHEUS_METRICS_BIND_HOST=127.0.0.1  # Default: localhost (secure)
# PROMETHEUS_METRICS_BIND_PORT=1974     # Port for metrics endpoint
# Metrics available at: http://HOST:PORT/metrics

# Prometheus TLS/HTTPS (optional)
PROMETHEUS_TLS_ENABLED=false
PROMETHEUS_TLS_CERT_FILE=/etc/resman/tls/server.crt
PROMETHEUS_TLS_KEY_FILE=/etc/resman/tls/server.key
PROMETHEUS_TLS_CA_FILE=/etc/resman/tls/ca.crt
PROMETHEUS_TLS_MIN_VERSION=1.2

# Prometheus Authentication (optional)
# Options: none, basic, jwt, both
PROMETHEUS_AUTH_TYPE=none
PROMETHEUS_AUTH_USERNAME=prometheus
PROMETHEUS_AUTH_PASSWORD_FILE=/etc/resman/prometheus_password
PROMETHEUS_JWT_SECRET_FILE=/etc/resman/jwt_secret
PROMETHEUS_JWT_ISSUER=resman
PROMETHEUS_JWT_AUDIENCE=prometheus
PROMETHEUS_JWT_EXPIRY=3600

# ========================
# LOGGING [D]
# ========================
# Available log levels:
#   DEBUG - Detailed messages for troubleshooting
#   INFO  - Normal operational information (recommended default)
#   WARN  - Warnings and errors only
#   ERROR - Errors only
LOG_LEVEL=INFO
LOG_MAX_SIZE=10485760        # Maximum log file size (10MB)
USE_SYSLOG=false             # true: use system syslog, false: use file
LOG_FILE=/var/log/resman.log

# ========================
# SYSTEM [S]
# ========================
MIN_SYSTEM_CORES=1

# SYSTEM_UID_MIN: Minimum UID to monitor and include in metrics
# Default: 1000
#
# MONITORING IMPACT:
# With SYSTEM_UID_MIN=1000 (default), only users with UID >= 1000 appear
# in Prometheus metrics. Users with UID < 1000 (mysql, avahi, www-data,
# postfix, etc.) are NOT visible in metrics.
#
# Example on a system with 20 active users:
#   - 15 users with UID < 1000 (mysql, avahi, www-data, etc.) → NOT in metrics
#   - 5 users with UID >= 1000 (francesco, openclaw, etc.) → present in metrics
#
# To monitor ALL users (including root, mysql, avahi, etc.):
#   SYSTEM_UID_MIN=0
#
# WARNING: SYSTEM_UID_MIN=0 includes root and system users in monitoring.
# You can still use USER_EXCLUDE_LIST=root to prevent limiting root.
SYSTEM_UID_MIN=1000

# SYSTEM_UID_MAX: Maximum UID to monitor
# Default: read automatically from /proc/sys/kernel/pid_max
# Typically: 32768, 65536, or 4194304 on modern systems
# SYSTEM_UID_MAX is read automatically from /proc/sys/kernel/pid_max

# ========================
# USER INCLUDE LIST [D]
# ========================
# If specified, INCLUDE in monitoring ONLY users matching the listed
# regex patterns. If empty or unspecified, NO users will be limited
# (monitoring is active but no limits are applied).
# Format: comma-separated regex patterns, no spaces
# Examples:
#   USER_INCLUDE_LIST=francesco                    # Only francesco can be limited
#   USER_INCLUDE_LIST=^www.*,^apache.*             # Web users (regex)
#   USER_INCLUDE_LIST=^svc-.*,^app-.*              # Service users (regex)
#   USER_INCLUDE_LIST=francesco,www-data,mysql     # Specific users
#   USER_INCLUDE_LIST=.*                           # ALL users can be limited
#   USER_INCLUDE_LIST=                             # Empty = NO users limited (default)
#
# IMPORTANT NOTE: If USER_INCLUDE_LIST is empty, resman monitors all users
# but does NOT apply limits to anyone. To limit all users, set
# USER_INCLUDE_LIST=.*
#
# USER_INCLUDE_LIST=

# ========================
# USER EXCLUDE LIST [D]
# ========================
# If specified, EXCLUDE listed users from monitoring and CPU limit
# application. If empty or unspecified, all non-system users
# (UID >= SYSTEM_UID_MIN) can be limited.
# Format: comma-separated regex patterns, no spaces
# Examples:
#   USER_EXCLUDE_LIST=francesco                    # Francesco is NOT limited
#   USER_EXCLUDE_LIST=^www-.*,^test-.*             # Excludes web and test users (regex)
#   USER_EXCLUDE_LIST=^svc-.*,^app-.*              # Excludes service users (regex)
#   USER_EXCLUDE_LIST=francesco,www-data,mysql     # Specific excluded users
#   USER_EXCLUDE_LIST=                             # Empty = NO users excluded (default)
#
# NOTE: If the line is absent or commented, all non-system users can be limited.
USER_EXCLUDE_LIST=root

# ========================
# PROCESS EXCLUDE LIST [D]
# ========================
# List of processes to exclude from CPU limits (comma-separated)
# These processes are NEVER limited, even if the user is in the INCLUDE_LIST
# Useful for protecting critical processes that could cause instability
# Supports regular expressions (regex) for advanced pattern matching
#
# Default: ^systemd$,^dbus-daemon$,^dbus-broker$,^polkitd$ (essential processes)
#
# Examples:
# # Only essential processes (default, exact match)
# PROCESS_EXCLUDE_LIST=^systemd$,^dbus-daemon$,^dbus-broker$,^polkitd$
#
# # Exact match for specific processes
# PROCESS_EXCLUDE_LIST=^sshd$,^cron$,^systemd-journald$
#
# # Pattern for all processes starting with "systemd-"
# PROCESS_EXCLUDE_LIST=^systemd-.*
#
# # Pattern for database processes (partial match)
# PROCESS_EXCLUDE_LIST=mysqld,postgres,redis,mongod
#
# # Extended list with mixed patterns
# PROCESS_EXCLUDE_LIST=^systemd-.*,^dbus-.*,sshd,cron,rsyslogd
#
# # No processes excluded (NOT recommended)
# PROCESS_EXCLUDE_LIST=
#
# WARNING: Excluding critical processes like systemd from the user can cause
# system instability. Use with caution and test in a non-production environment.
PROCESS_EXCLUDE_LIST=^systemd$,^dbus-daemon$,^dbus-broker$,^polkitd$

# ========================
# BLACKOUT TIMEFRAMES [D]
# ========================
# Specifies when ResMan should NOT apply CPU limits.
# Format: "days hours" (multiple timeframes separated by ;)
#
# Days: 0=Sunday, 1=Mon, 2=Tue, 3=Wed, 4=Thu, 5=Fri, 6=Sat
#       Or: * (all), 1-5 (Mon-Fri), 0,6 (weekend)
# Hours: 24h format (00-23)
#
# Examples:
#
# # Disable during working hours (Mon-Fri, 8-18)
# BLACKOUT=1-5 08-18
#
# # Disable mornings only (Mon-Fri, 8-12)
# BLACKOUT=1-5 08-12
#
# # Disable on weekends (Sat-Sun, all day)
# BLACKOUT=0,6 00-23
#
# # Disable working hours + weekend
# BLACKOUT=1-5 08-18;0,6 00-23
#
# # Disable always (for testing)
# BLACKOUT=* 00-23
#
# # No blackout (default - ResMan always active)
BLACKOUT=

# ========================
# LOAD AVERAGE HANDLING [D]
# ========================
# false: do not activate limits if the system is already under load (conservative default)
# true: activate limits even if the system is under load (guaranteed isolation)
IGNORE_SYSTEM_LOAD=true

# ========================
# SERVER ROLE [S]
# ========================
# Optional: describes the role of this server for identification in MCP reports
# and Prometheus labels (server_role).
# Requires restart to apply to Prometheus metrics.
# Examples: database, web-frontend, batch, application, cache, api-gateway, etc.
# SERVER_ROLE=database

# ========================
# MCP SERVER (Model Context Protocol) [S]
# ========================
# Enable MCP server for AI assistant integration
MCP_ENABLED=false

# Transport: stdio, http
# stdio: Standard input/output (for local MCP clients like Claude Desktop)
# http: HTTP POST endpoint (for AnythingLLM and other remote clients)
MCP_TRANSPORT=stdio

# HTTP transport settings (only for http transport)
# MCP_HTTP_HOST=0.0.0.0      # Bind address (default: all interfaces)
# MCP_HTTP_PORT=1969         # Port for MCP endpoint (default: 1969)
# MCP endpoint available at: http://HOST:PORT/mcp

# MCP log level [D]
# Available levels: DEBUG, INFO, WARN, ERROR
# If not specified, uses the same level as LOG_LEVEL
MCP_LOG_LEVEL=INFO

# Allow write operations (activate/deactivate limits via MCP)
# WARNING: Enable only if you trust all MCP clients
MCP_ALLOW_WRITE_OPS=false

# Optional authentication token for HTTP transport
# MCP_AUTH_TOKEN=your-secret-token-here

# ========================
# METRICS DATABASE (SQLite) [S]
# ========================
# Enable persistence of metrics in a local SQLite database
# to expose metric history via MCP.
#
# METRICS_DB_ENABLED: Enable (true) or disable (false) database writing
# Default: false (disabled)
#
# METRICS_DB_PATH: Path to the SQLite database
# Default: /etc/resman/metrics.db
# Ensure the directory exists and is writable
#
# METRICS_DB_RETENTION_DAYS: How many days to keep data in the database
# Default: 30 days
# Older data is automatically deleted
#
# METRICS_DB_WRITE_INTERVAL: How often (in seconds) to write metrics to the database
# Default: 30 seconds (same as POLLING_INTERVAL)
# Do not set too low to avoid overloading the database
# Minimum: 5 seconds
#
# Examples:
# # Enable database with 30-day retention
# METRICS_DB_ENABLED=true
# METRICS_DB_PATH=/etc/resman/metrics.db
# METRICS_DB_RETENTION_DAYS=30
# METRICS_DB_WRITE_INTERVAL=30
#
# # In-memory database (faster, data lost on restart)
# METRICS_DB_ENABLED=true
# METRICS_DB_PATH=:memory:
#
# # Extended retention (90 days)
# METRICS_DB_ENABLED=true
# METRICS_DB_RETENTION_DAYS=90
#
METRICS_DB_ENABLED=false
METRICS_DB_PATH=/etc/resman/metrics.db
METRICS_DB_RETENTION_DAYS=30
METRICS_DB_WRITE_INTERVAL=30

# ========================
# USERNAME CACHE TTL [D]
# ========================
# Cache duration for UID -> username resolution (in minutes)
# Useful for reducing LDAP/NIS calls in environments with many users
#
# USERNAME_CACHE_TTL: How many minutes to cache username resolution
# Default: 60 minutes
# Minimum: 1 minute
#
# Examples:
# # Short cache (5 minutes) - for environments with frequently changing users
# USERNAME_CACHE_TTL=5
#
# # Medium cache (30 minutes) - balance between performance and freshness
# USERNAME_CACHE_TTL=30
#
# # Long cache (2 hours) - maximum performance, stable users
# USERNAME_CACHE_TTL=120
#
# # Default: 60 minutes
USERNAME_CACHE_TTL=60
